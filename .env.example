# ---- Database / Auth (Supabase) ----
# Public values: safe to ship in client bundles.
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Same URL/key, exposed to the server runtime (SSR + server functions).
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"

# SERVICE ROLE KEY — server only. NEVER expose to the client.
# Used by server routes / functions to bypass RLS for admin operations.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---- AI Provider (pick ONE) ----
# The backend auto-detects which one is set, in this priority order:
#   1. OPENAI_API_KEY   -> https://api.openai.com
#   2. GEMINI_API_KEY   -> Google Gemini (OpenAI-compatible endpoint)
#   3. LOVABLE_API_KEY  -> Lovable AI Gateway (default on lovable.app)
#
# Get an OpenAI key:  https://platform.openai.com/api-keys
# Get a Gemini key:   https://aistudio.google.com/app/apikey
OPENAI_API_KEY=""
GEMINI_API_KEY=""
LOVABLE_API_KEY=""

# ---- Optional model overrides ----
# AI_TEXT_MODEL="gpt-4o-mini"            # or "gemini-2.5-flash", etc.
# AI_IMAGE_MODEL="gpt-image-1"           # or "gemini-2.5-flash-image"
# AI_BASE_URL="https://api.openai.com/v1"  # custom OpenAI-compatible gateway
